# ===== StudyStake BNB Chain 部署配置 =====
# 复制此文件为 .env 并填入真实值

# 部署钱包私钥（需有足够 BNB 支付 gas）
PRIVATE_KEY=

# BNB Chain 上 USDC 地址（Binance-Peg USD Coin，已填好）
USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# 罚金接收地址（用户违约 slashed 时罚金打到这个地址）
PENALTY_RECEIVER=

# BNB Chain RPC URL
RPC_URL=https://bsc-dataseed1.binance.org

# BscScan API Key（用于合约验证，在 https://bscscan.com 申请）
BSCSCAN_API_KEY=
